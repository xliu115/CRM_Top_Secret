generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Partner {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  avatarUrl       String?  @map("avatar_url")
  briefingEnabled Boolean  @default(true) @map("briefing_enabled")
  timezone        String   @default("America/New_York") @map("timezone")
  createdAt       DateTime @default(now()) @map("created_at")

  contacts           Contact[]
  meetings           Meeting[]
  nudgeRuleConfig    NudgeRuleConfig?
  outreachSequences  OutreachSequence[]
  campaigns          Campaign[]

  @@map("partners")
}

model Company {
  id            String @id @default(uuid())
  name          String @unique
  industry      String
  description   String
  employeeCount Int    @map("employee_count")
  website       String

  contacts Contact[]
  signals  ExternalSignal[]

  @@map("companies")
}

model Contact {
  id            String   @id @default(uuid())
  partnerId     String   @map("partner_id")
  companyId     String   @map("company_id")
  name          String
  email         String
  title         String
  phone         String?
  importance         String   @default("MEDIUM")
  notes              String?
  lastContacted      DateTime? @map("last_contacted")
  staleThresholdDays Int?      @map("stale_threshold_days")
  disabledNudgeTypes String?   @map("disabled_nudge_types")
  createdAt          DateTime  @default(now()) @map("created_at")

  partner            Partner            @relation(fields: [partnerId], references: [id])
  company            Company            @relation(fields: [companyId], references: [id])
  interactions       Interaction[]
  signals            ExternalSignal[]
  nudges             Nudge[]
  meetings           MeetingAttendee[]
  events             EventRegistration[]
  articles           ArticleEngagement[]
  campaigns          CampaignOutreach[]
  campaignRecipients CampaignRecipient[]
  outreachSequences  OutreachSequence[]

  @@index([partnerId])
  @@index([companyId])
  @@map("contacts")
}

model Interaction {
  id             String    @id @default(uuid())
  contactId      String    @map("contact_id")
  type           String
  date           DateTime
  summary        String
  sentiment      String    @default("NEUTRAL")
  nextStep       String?   @map("next_step")
  direction      String?   @map("direction")
  cadenceStepId  String?   @map("cadence_step_id")
  repliedAt      DateTime? @map("replied_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  contact     Contact      @relation(fields: [contactId], references: [id])
  cadenceStep CadenceStep? @relation(fields: [cadenceStepId], references: [id])

  @@index([contactId])
  @@index([date])
  @@index([direction])
  @@map("interactions")
}

model ExternalSignal {
  id         String   @id @default(uuid())
  contactId  String?  @map("contact_id")
  companyId  String?  @map("company_id")
  type       String
  date       DateTime
  content    String
  url        String?
  confidence Float    @default(0.8)
  createdAt  DateTime @default(now()) @map("created_at")

  contact Contact? @relation(fields: [contactId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])
  nudges  Nudge[]

  @@index([contactId])
  @@index([companyId])
  @@index([date])
  @@map("external_signals")
}

model Nudge {
  id             String   @id @default(uuid())
  contactId      String   @map("contact_id")
  signalId       String?  @map("signal_id")
  ruleType       String   @map("rule_type")
  reason         String
  priority       String   @default("MEDIUM")
  status         String   @default("OPEN")
  generatedEmail String?  @map("generated_email")
  metadata       String?  @map("metadata")
  sequenceId     String?  @map("sequence_id")
  cadenceStepId  String?  @map("cadence_step_id")
  createdAt      DateTime @default(now()) @map("created_at")

  contact      Contact           @relation(fields: [contactId], references: [id])
  signal       ExternalSignal?   @relation(fields: [signalId], references: [id])
  sequence     OutreachSequence? @relation("SequenceNudges", fields: [sequenceId], references: [id])
  cadenceStep  CadenceStep?      @relation("StepNudge", fields: [cadenceStepId], references: [id])

  @@index([contactId])
  @@index([status])
  @@index([priority])
  @@index([contactId, status])
  @@index([sequenceId])
  @@map("nudges")
}

model OutreachSequence {
  id            String    @id @default(uuid())
  contactId     String    @map("contact_id")
  partnerId     String    @map("partner_id")
  originNudgeId String    @map("origin_nudge_id")
  status        String    @default("ACTIVE")
  currentStep   Int       @default(0) @map("current_step")
  totalSteps    Int       @default(4) @map("total_steps")
  angleStrategy String    @default("check-in") @map("angle_strategy")
  nextStepAt    DateTime? @map("next_step_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  contact Contact  @relation(fields: [contactId], references: [id])
  partner Partner  @relation(fields: [partnerId], references: [id])
  steps   CadenceStep[]
  nudges  Nudge[]  @relation("SequenceNudges")

  @@index([contactId])
  @@index([partnerId])
  @@index([status])
  @@index([nextStepAt])
  @@map("outreach_sequences")
}

model CadenceStep {
  id                 String    @id @default(uuid())
  sequenceId         String    @map("sequence_id")
  stepNumber         Int       @map("step_number")
  type               String    @default("INITIAL")
  status             String    @default("PENDING")
  scheduledAt        DateTime  @map("scheduled_at")
  executedAt         DateTime? @map("executed_at")
  emailSubject       String?   @map("email_subject")
  emailBody          String?   @map("email_body")
  responseDetectedAt DateTime? @map("response_detected_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  sequence     OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  nudges       Nudge[]          @relation("StepNudge")
  interactions Interaction[]

  @@index([sequenceId])
  @@index([status])
  @@map("cadence_steps")
}

model Meeting {
  id             String   @id @default(uuid())
  partnerId      String   @map("partner_id")
  startTime      DateTime @map("start_time")
  title          String
  purpose        String?
  notes          String?
  generatedBrief String?  @map("generated_brief")
  createdAt      DateTime @default(now()) @map("created_at")

  partner   Partner           @relation(fields: [partnerId], references: [id])
  attendees MeetingAttendee[]

  @@index([partnerId])
  @@index([startTime])
  @@index([partnerId, startTime])
  @@map("meetings")
}

model MeetingAttendee {
  id         String  @id @default(uuid())
  meetingId  String  @map("meeting_id")
  contactId  String  @map("contact_id")
  isRequired Boolean @default(true) @map("is_required")

  meeting Meeting @relation(fields: [meetingId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([meetingId, contactId])
  @@index([contactId])
  @@map("meeting_attendees")
}

model EventRegistration {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  name      String
  status    String   @default("Registered")
  eventDate DateTime @map("event_date")
  practice  String
  type      String   @default("In-person")
  eventSize String?  @map("event_size")
  location  String?
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@map("event_registrations")
}

model ArticleEngagement {
  id          String    @id @default(uuid())
  contactId   String    @map("contact_id")
  name        String
  articleSent String    @default("Y") @map("article_sent")
  views       Int       @default(0)
  sentFrom    String?   @map("sent_from")
  lastViewDate DateTime? @map("last_view_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@map("article_engagements")
}

model CampaignOutreach {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  name       String
  status     String   @default("Sent")
  statusDate DateTime @map("status_date")
  createdAt  DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@map("campaign_outreaches")
}

model ContentItem {
  id            String    @id @default(uuid())
  type          String
  title         String
  description   String?
  url           String?
  imageUrl      String?   @map("image_url")
  practice      String?
  publishedAt   DateTime? @map("published_at")
  eventDate     DateTime? @map("event_date")
  eventLocation String?   @map("event_location")
  eventType     String?   @map("event_type")
  sourceId      String?   @map("source_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  campaignContents CampaignContent[]
  engagements      CampaignEngagement[]

  @@index([type])
  @@index([practice])
  @@index([sourceId])
  @@map("content_items")
}

model Campaign {
  id              String    @id @default(uuid())
  partnerId       String    @map("partner_id")
  name            String
  subject         String?
  bodyTemplate    String?   @map("body_template")
  signatureBlock  String?   @map("signature_block")
  source          String    @default("ACTIVATE")
  status          String    @default("DRAFT")
  segmentCriteria String?   @map("segment_criteria")
  sentAt          DateTime? @map("sent_at")
  sendStartedAt   DateTime? @map("send_started_at")
  lastError       String?   @map("last_error")
  importedFrom    String?   @map("imported_from")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  partner    Partner             @relation(fields: [partnerId], references: [id])
  contents   CampaignContent[]
  recipients CampaignRecipient[]

  @@index([partnerId])
  @@index([partnerId, status])
  @@index([status])
  @@map("campaigns")
}

model CampaignContent {
  id            String @id @default(uuid())
  campaignId    String @map("campaign_id")
  contentItemId String @map("content_item_id")
  position      Int    @default(0)

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contentItem ContentItem @relation(fields: [contentItemId], references: [id])

  @@unique([campaignId, contentItemId])
  @@index([campaignId])
  @@index([contentItemId])
  @@map("campaign_contents")
}

model CampaignRecipient {
  id              String    @id @default(uuid())
  campaignId      String    @map("campaign_id")
  contactId       String?   @map("contact_id")
  unmatchedEmail  String?   @map("unmatched_email")
  personalizedBody String?  @map("personalized_body")
  rsvpToken       String?   @map("rsvp_token")
  rsvpStatus      String?   @map("rsvp_status")
  rsvpRespondedAt DateTime? @map("rsvp_responded_at")
  status          String    @default("PENDING")
  failureReason   String?   @map("failure_reason")
  sentAt          DateTime? @map("sent_at")

  campaign    Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact?             @relation(fields: [contactId], references: [id])
  engagements CampaignEngagement[]

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@index([campaignId, status])
  @@index([rsvpToken])
  @@map("campaign_recipients")
}

model CampaignEngagement {
  id            String    @id @default(uuid())
  recipientId   String    @map("recipient_id")
  type          String
  contentItemId String?   @map("content_item_id")
  timestamp     DateTime  @default(now())
  metadata      String?

  recipient   CampaignRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  contentItem ContentItem?      @relation(fields: [contentItemId], references: [id])

  @@index([recipientId])
  @@index([recipientId, type])
  @@index([contentItemId])
  @@map("campaign_engagements")
}

model NudgeRuleConfig {
  id        String   @id @default(uuid())
  partnerId String   @unique @map("partner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  staleContactEnabled    Boolean @default(true) @map("stale_contact_enabled")
  jobChangeEnabled       Boolean @default(true) @map("job_change_enabled")
  companyNewsEnabled     Boolean @default(true) @map("company_news_enabled")
  upcomingEventEnabled   Boolean @default(true) @map("upcoming_event_enabled")
  meetingPrepEnabled     Boolean @default(true) @map("meeting_prep_enabled")
  eventAttendedEnabled   Boolean @default(true) @map("event_attended_enabled")
  eventRegisteredEnabled Boolean @default(true) @map("event_registered_enabled")
  articleReadEnabled     Boolean @default(true) @map("article_read_enabled")
  linkedinActivityEnabled Boolean @default(true) @map("linkedin_activity_enabled")

  staleDaysCritical Int @default(30) @map("stale_days_critical")
  staleDaysHigh     Int @default(45) @map("stale_days_high")
  staleDaysMedium   Int @default(60) @map("stale_days_medium")
  staleDaysLow      Int @default(90) @map("stale_days_low")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("nudge_rule_configs")
}
