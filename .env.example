# SQLite (default for local dev – zero setup)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production / Docker setup)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chirp"

NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional – falls back to deterministic templates when absent
OPENAI_API_KEY=

# Email notifications (Resend) – optional
# Get a free API key at https://resend.com
RESEND_API_KEY=
RESEND_FROM="Chirp <onboarding@resend.dev>"
# Override recipient for all nudge emails (useful for dev/demo)
NUDGE_EMAIL_TO=
