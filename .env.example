# Activate — CRM Nudge Platform
# Copy this file to .env.local and fill in your values

# ── Database ────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Authentication ──────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── OpenAI (LLM features: email drafts, briefings, chat) ──
OPENAI_API_KEY="sk-..."

# ── Resend (email delivery) ─────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="Activate <onboarding@resend.dev>"

# ── Tavily (company news ingestion) ─────────────────────────
TAVILY_API_KEY="tvly-..."

# ── Twilio (SMS nudge channel) ──────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Cron / Scheduled Jobs ──────────────────────────────────
# Required for /api/cron/* routes. Send as x-cron-secret header.
CRON_SECRET="your-cron-secret-here"

# ── Dev Overrides (remove in production) ────────────────────
# Forces all nudge emails to this address instead of the partner's
NUDGE_EMAIL_TO=""
# Forces all SMS to this number instead of the contact's
NUDGE_SMS_TO=""
